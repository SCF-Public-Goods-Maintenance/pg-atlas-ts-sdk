{
  "name": "@pg-atlas/data-sdk",
  "version": "0.4.0",
  "description": "TypeScript SDK for the PG Atlas API",
  "keywords": [
    "stellar",
    "soroban",
    "public-goods",
    "atlas",
    "sdk"
  ],
  "author": "PG Atlas Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SCF-Public-Goods-Maintenance/pg-atlas-ts-sdk.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "generate": "openapi-ts",
    "update": "node ./scripts/update-api.cjs && pnpm run generate",
    "rewrite-tests": "node ./scripts/rewrite-tests.cjs",
    "test": "vitest run src/index.test.ts",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.95.0",
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
