{
  "name": "@pg-atlas/sdk",
  "version": "0.3.0",
  "description": "TypeScript SDK for the PG Atlas API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "generate": "openapi-ts",
    "update": "node ./scripts/update-api.cjs && npm run generate",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "stellar",
    "soroban",
    "public-goods",
    "atlas",
    "sdk"
  ],
  "author": "PG Atlas Contributors",
  "license": "MIT",
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.90.10",
    "typescript": "^5.5.3",
    "vitest": "^1.4.0"
  }
}
